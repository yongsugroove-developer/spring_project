STORAGE_DRIVER=mysql
PORT=3000

MYSQL_HOST=replace-with-db-host
MYSQL_PORT=3306
MYSQL_DATABASE=my_planner
MYSQL_USER=replace-with-db-user
MYSQL_PASSWORD=replace-with-strong-db-password
MYSQL_CONNECTION_LIMIT=10

AUTH_REQUIRED=true
AUTH_SESSION_TTL_HOURS=720
BOOTSTRAP_ADMIN_EMAIL=owner@example.com
BOOTSTRAP_ADMIN_PASSWORD=replace-with-strong-admin-password
BOOTSTRAP_ADMIN_NAME=Planner Owner
PUBLIC_BILLING_ENABLED=false
PUBLIC_INSTALL_GUIDE_PATH=/install

BILLING_CURRENCY=KRW
