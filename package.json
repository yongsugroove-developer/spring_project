{
  "name": "my-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/server.ts",
    "db:mysql:start": "powershell -ExecutionPolicy Bypass -File scripts/start-local-mysql.ps1",
    "db:mysql:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-local-mysql.ps1",
    "mobile:android:add": "npx cap add android",
    "mobile:android:release": "powershell -ExecutionPolicy Bypass -File scripts/build-android-release.ps1",
    "mobile:android:sync": "npx cap sync android",
    "mobile:android:open": "npx cap open android",
    "deploy:verify:public": "powershell -ExecutionPolicy Bypass -File scripts/verify-public-deploy.ps1",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint src tests --ext .ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.0",
    "@capacitor/core": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.10"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@eslint/js": "^9.35.0",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.3",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.35.0",
    "globals": "^16.4.0",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vitest": "^3.2.4"
  }
}
